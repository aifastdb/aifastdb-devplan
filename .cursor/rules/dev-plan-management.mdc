## 完整工作流示例

用户说："修改 aifastdb-devplan 项目，在 3D 图谱中添加呼吸灯效果"

```
// 第 1 批工具调用：保存 Prompt + 查看任务状态 + 召回相关记忆
batch 1: [
  devplan_save_prompt(projectName: "aifastdb-devplan", content: "...", ...),
  devplan_list_tasks(projectName: "aifastdb-devplan"),
  devplan_memory_context(projectName: "aifastdb-devplan", query: "3D 图谱呼吸灯"),
]

// 第 2 批：创建任务（如果没有合适的 in_progress 阶段）
batch 2: [
  devplan_create_main_task(projectName: "aifastdb-devplan", taskId: "phase-14B", title: "...", priority: "P1"),
  devplan_add_sub_task(projectName: "aifastdb-devplan", taskId: "T14B.1", parentTaskId: "phase-14B", title: "..."),
  devplan_add_sub_task(projectName: "aifastdb-devplan", taskId: "T14B.2", parentTaskId: "phase-14B", title: "..."),
]

// ... 执行代码修改 ...

// 完成后：标记任务 + 保存重要记忆（如有 Bug 修复或决策）
batch N: [
  devplan_complete_task(projectName: "aifastdb-devplan", taskId: "T14B.1"),
  devplan_complete_task(projectName: "aifastdb-devplan", taskId: "T14B.2"),
  devplan_memory_save_cursor_profile(projectName: "aifastdb-devplan", conversationId: "...", userId: "...", userContent: "...", assistantContent: "呼吸灯效果使用 CSS animation 实现...", profile: "cursor", hookPhase: "post_response"),
]
```

